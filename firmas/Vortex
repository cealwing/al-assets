<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/cealwing/forum@main/signatures/vortex.css?v=1.2">

<style>
  /* CSS Crítico: Se ejecuta aunque GitHub falle */
  .vortex-container {
      display: flex !important;
      width: 450px;
      height: 140px;
      background: #0a0a0a !important; /* Fondo oscuro sólido */
      border: 1px solid #222 !important;
      border-left: 4px solid #9b59b6 !important; /* Línea neón */
      overflow: hidden;
      font-family: 'Segoe UI', Tahoma, sans-serif;
      margin: 10px 0;
      position: relative;
  }

  .vx-main {
      padding: 20px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      z-index: 2;
  }

  .vx-name {
      font-size: 26px !important;
      font-weight: 900 !important;
      color: #ffffff !important;
      letter-spacing: 5px !important;
      text-transform: uppercase;
      margin: 0;
      line-height: 1.2;
  }

  .vx-details {
      font-size: 10px !important;
      color: #9b59b6 !important;
      letter-spacing: 2px !important;
      margin-top: 5px;
      opacity: 0.8;
  }

  /* Animación de pulso básica */
  .vortex-container::before {
      content: '';
      position: absolute;
      width: 100%; height: 100%;
      background: radial-gradient(circle at center, rgba(155, 89, 182, 0.1) 0%, transparent 70%);
      animation: vx-pulse 3s infinite alternate;
  }

  @keyframes vx-pulse {
      from { opacity: 0.3; } to { opacity: 0.7; }
  }
</style>

<div class="vortex-container">
    <div class="vx-main">
        <div class="vx-name">VORTEX</div>
        <div class="vx-details">ENTITY ID: 00-VX // STATUS: STABLE</div>
    </div>
</div>
